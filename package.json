{
  "name": "mayormono",
  "version": "1.0.0",
  "description": "Mayormono - Tu asistente personal para Mac",
  "main": "out/main/index.js",
  "author": "Javier Donoso",
  "license": "MIT",
  "scripts": {
    "dev": "ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && ELECTRON_RUN_AS_NODE= electron-builder --mac dmg --config.directories.output=/private/tmp/mm-release && cp /private/tmp/mm-release/*.dmg release/ && cp /private/tmp/mm-release/latest-mac.yml release/"
  },
  "build": {
    "appId": "com.javierdonoso.mayormono",
    "productName": "Mayormono",
    "copyright": "Copyright © 2026 Javier Donoso",
    "directories": {
      "output": "release"
    },
    "afterPack": "./build/afterPack.js",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "darkModeSupport": true,
      "icon": "resources/icon.icns",
      "identity": null
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": ["**/*"]
      }
    ],
    "asar": true
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^35.7.5",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "marked": "^18.0.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  }
}
